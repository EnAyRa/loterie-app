<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loterie Royale 🎰</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <script src="/socket.io/socket.io.js"></script>
</head>
<body>

    <div id="annonce-gagnant"></div>

    <header class="header">
        <h1>LOTERIE ROYALE 👑</h1>
        <p>Bienvenue, <strong><%= user.username %></strong></p>
        <div class="balance-card">
            <div class="balance-amount"><span id="solde"><%= user.balance.toLocaleString() %></span> $</div>
        </div>
    </header>

    <div class="container">
        <% if (typeof message !== 'undefined') { %>
            <div style="background: rgba(255,255,255,0.1); padding: 10px; border-radius: 10px; margin: 10px 0; border-left: 5px solid var(--primary);">
                <%= message %>
            </div>
        <% } %>

        <div class="loteries-grid">
            <div class="card">
                <h3>⚡ EXPRESS</h3>
                <p>Tirage toutes les 5 min</p>
                <div class="timer" id="timer-5min">00:00</div>
                <form action="/participer" method="POST">
                    <input type="hidden" name="lotteryType" value="5min">
                    <button type="submit" class="btn-play">PARTICIPER (500$)</button>
                </form>
            </div>

            <div class="card">
                <h3>⏳ HORAIRE</h3>
                <p>Tirage chaque heure</p>
                <div class="timer" id="timer-1h">00:00</div>
                <form action="/participer" method="POST">
                    <input type="hidden" name="lotteryType" value="1h">
                    <button type="submit" class="btn-play">PARTICIPER (500$)</button>
                </form>
            </div>

            <div class="card">
                <h3>📅 QUOTIDIEN</h3>
                <p>Tirage à minuit</p>
                <div class="timer" id="timer-1j">00:00</div>
                <form action="/participer" method="POST">
                    <input type="hidden" name="lotteryType" value="1j">
                    <button type="submit" class="btn-play">PARTICIPER (500$)</button>
                </form>
            </div>
        </div>

        <div style="text-align: center; margin-top: 50px;">
            <a href="/logout" style="color: #666; text-decoration: none;">Se déconnecter</a>
        </div>
    </div>

    <script>
        const socket = io();
        socket.on('resultat_loterie', (data) => {
            const annonceBox = document.getElementById('annonce-gagnant');
            annonceBox.innerHTML = `🏆 FÉLICITATIONS ! <br> ${data.message}`;
            annonceBox.style.display = 'block';
            setTimeout(() => { annonceBox.style.display = 'none'; }, 8000);
        });

        function updateTimers() {
            const now = new Date();
            
            // On calcule les temps restants (simplifié pour l'exemple)
            const format = (ms) => {
                let s = Math.floor(ms / 1000);
                let m = Math.floor(s / 60);
                let h = Math.floor(m / 60);
                return `${String(h).padStart(2, '0')}:${String(m % 60).padStart(2, '0')}:${String(s % 60).padStart(2, '0')}`;
            };

            // 5 min timer
            let next5m = new Date();
            next5m.setMinutes(Math.ceil(now.getMinutes() / 5) * 5, 0, 0);
            document.getElementById('timer-5min').innerText = format(next5m - now);

            // 1h timer
            let next1h = new Date();
            next1h.setHours(now.getHours() + 1, 0, 0, 0);
            document.getElementById('timer-1h').innerText = format(next1h - now);

            // 1j timer
            let next1j = new Date();
            next1j.setHours(24, 0, 0, 0);
            document.getElementById('timer-1j').innerText = format(next1j - now);
        }

        setInterval(updateTimers, 1000);
        updateTimers();
    </script>
</body>
</html>