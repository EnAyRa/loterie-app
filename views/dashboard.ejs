<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loterie - Tableau de bord</title>
    <script src="/socket.io/socket.io.js"></script>
    <style>
        body { font-family: Arial, sans-serif; text-align: center; margin-top: 30px; }
        .balance { font-size: 2em; color: #28a745; font-weight: bold; }
        .loteries { display: flex; justify-content: center; gap: 20px; margin-top: 30px; flex-wrap: wrap; }
        .carte-loterie { border: 2px solid #333; padding: 20px; border-radius: 10px; width: 220px; background: #f9f9f9; }
        .btn { padding: 10px 15px; background-color: #007BFF; color: white; border: none; border-radius: 5px; cursor: pointer; text-decoration: none; width: 100%; margin-top: 10px; }
        .btn:hover { background-color: #0056b3; }
        .btn-logout { background-color: #dc3545; margin-top: 40px; display: inline-block; width: auto; }
        .decompte { font-size: 1.2em; color: #d35400; font-weight: bold; margin: 10px 0; }
        
        /* La boîte d'annonce du gagnant */
        #annonce-gagnant {
            display: none;
            background-color: #ffeb3b;
            color: #d35400;
            padding: 20px;
            margin: 20px auto;
            width: 80%;
            border-radius: 10px;
            font-size: 1.5em;
            font-weight: bold;
            border: 3px solid #d35400;
            animation: clignote 1s infinite;
        }
        @keyframes clignote {
            0% { box-shadow: 0 0 10px #ffeb3b; }
            50% { box-shadow: 0 0 30px #d35400; }
            100% { box-shadow: 0 0 10px #ffeb3b; }
        }
    </style>
</head>
<body>

    <h1>Bienvenue dans ton espace de jeu, <%= user.username %> ! 🎰</h1>
    <p>Ton solde actuel :</p>
    <p class="balance"><span id="solde"><%= user.balance.toLocaleString() %></span> $</p>

    <div id="annonce-gagnant"></div>

    <% if (typeof message !== 'undefined') { %>
        <h3 style="color: #d35400;"><%= message %></h3>
    <% } %>

    <h2>Choisis ta Loterie (Prix : 500 $)</h2>

    <div class="loteries">
        <div class="carte-loterie">
            <h3>⚡ 5 Minutes</h3>
            <div class="decompte" id="timer-5min">Calcul...</div>
            <form action="/participer" method="POST">
                <input type="hidden" name="lotteryType" value="5min">
                <button type="submit" class="btn">Participer</button>
            </form>
        </div>

        <div class="carte-loterie">
            <h3>⏳ 1 Heure</h3>
            <div class="decompte" id="timer-1h">Calcul...</div>
            <form action="/participer" method="POST">
                <input type="hidden" name="lotteryType" value="1h">
                <button type="submit" class="btn">Participer</button>
            </form>
        </div>

        <div class="carte-loterie">
            <h3>📅 1 Jour</h3>
            <div class="decompte" id="timer-1j">Calcul...</div>
            <form action="/participer" method="POST">
                <input type="hidden" name="lotteryType" value="1j">
                <button type="submit" class="btn">Participer</button>
            </form>
        </div>
    </div>

    <br>
    <a href="/logout" class="btn btn-logout">Se déconnecter</a>

    <script>
        // 1. Écouter le serveur en temps réel
        const socket = io();
        
        socket.on('resultat_loterie', (data) => {
            // On affiche la boîte avec le gagnant
            const annonceBox = document.getElementById('annonce-gagnant');
            annonceBox.innerHTML = `Loterie ${data.typeLoterie} : ${data.message}`;
            annonceBox.style.display = 'block';

            // On la fait disparaître après 10 secondes
            setTimeout(() => { annonceBox.style.display = 'none'; }, 10000);
        });

        // 2. Calculer les décomptes
        function updateTimers() {
            const now = new Date();

            // Prochaine minute pile (car on a mis le cron 5min sur 1min pour tester)
            // QUAND TU REMETTRAS SUR 5 MIN, on changera ce calcul !
            let next1Min = new Date();
            next1Min.setMinutes(now.getMinutes() + 1, 0, 0);
            let diff5min = Math.floor((next1Min - now) / 1000);
            document.getElementById('timer-5min').innerText = diff5min + " sec";

            // Prochaine heure pile
            let next1h = new Date();
            next1h.setHours(now.getHours() + 1, 0, 0, 0);
            let diff1h = Math.floor((next1h - now) / 1000);
            let m1 = Math.floor(diff1h / 60); let s1 = diff1h % 60;
            document.getElementById('timer-1h').innerText = `${m1}m ${s1}s`;

            // Prochain jour (minuit)
            let next1j = new Date();
            next1j.setDate(now.getDate() + 1);
            next1j.setHours(0, 0, 0, 0);
            let diff1j = Math.floor((next1j - now) / 1000);
            let h2 = Math.floor(diff1j / 3600); let m2 = Math.floor((diff1j % 3600) / 60);
            document.getElementById('timer-1j').innerText = `${h2}h ${m2}m`;
        }

        // Mettre à jour les chronos toutes les secondes
        setInterval(updateTimers, 1000);
        updateTimers(); // Lancer tout de suite
    </script>
</body>
</html>