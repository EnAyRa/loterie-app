<!DOCTYPE html>
<html lang="fr">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bienvenue - Loterie Royale 👑</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <header class="header">
        <h1>LOTERIE ROYALE 👑</h1>
        <p>Tentez votre chance avec vos jetons gratuits !</p>
    </header>

    <div class="container">
        <div class="auth-container">

            <div class="auth-card">
                <h2>Créer un compte</h2>
                <form action="/register" method="POST">
                    <div class="input-group">
                        <input type="text" name="username" placeholder="Pseudo" required>
                    </div>
                    <div class="input-group">
                        <input type="email" name="email" placeholder="Email" required>
                    </div>
                    <div class="input-group">
                        <input type="password" name="password" placeholder="Mot de passe" required>
                    </div>
                    <label class="checkbox-group">
                        <input type="checkbox" name="notifyByEmail"> M'avertir par mail en cas de gain
                    </label>
                    <button type="submit" class="btn-play">S'INSCRIRE</button>
                </form>
            </div>

            <div class="auth-card">
                <h2>Se connecter</h2>
                <form action="/login" method="POST">
                    <div class="input-group">
                        <input type="email" name="email" placeholder="Email" required>
                    </div>
                    <div class="input-group">
                        <input type="password" name="password" placeholder="Mot de passe" required>
                    </div>
                    <button type="submit" class="btn-play">CONNEXION</button>
                </form>

                <div style="margin: 20px 0; color: #666;">OU</div>

                    <a href="/auth/google" class="btn-google">
                        <img src="https://developers.google.com/static/identity/images/g-logo.png" alt="Google"
                            width="20">
                        Continuer avec Google
                    </a>
                </a>
            </div>

        </div>
    </div>

    <footer style="margin-top: 50px; color: #444; font-size: 0.8rem;">
        &copy; 2026 Loterie Royale - Jeu gratuit uniquement
    </footer>

</body>

</html>